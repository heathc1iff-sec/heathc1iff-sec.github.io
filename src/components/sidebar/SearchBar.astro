---
import { t } from "@config";
import { Icon } from "astro-icon/components";
import Card from "../temple/Card.astro";
---

<Card>
  <div class="p-4">
    <form action="/blog/search" method="get" class="relative w-full group">
      <div class="search-container w-full relative">
        <input
          type="text"
          name="q"
          placeholder={t("label.search") || "Search..."}
          class="input w-full pl-11 pr-12 py-3 bg-base-content/5 border-none focus:bg-base-100 focus:ring-2 focus:ring-primary/30 transition-all duration-300 rounded-2xl text-sm font-medium"
          aria-label={t("label.search") || "Search"}
        />
        <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-base-content/40 group-focus-within:text-primary transition-colors">
          <Icon name="lucide:search" class="w-4.5 h-4.5" />
        </div>
        <div class="absolute right-3 top-1/2 -translate-y-1/2 flex items-center gap-1">
          <kbd class="hidden md:inline-flex kbd kbd-sm bg-base-content/10 border-none text-[10px] opacity-40 group-focus-within:opacity-0 transition-opacity">/</kbd>
          <button
            type="submit"
            class="p-2 bg-primary/10 text-primary rounded-xl opacity-0 group-focus-within:opacity-100 transition-all duration-300 hover:bg-primary hover:text-primary-content"
            aria-label={t("label.search") || "Search"}
          >
            <Icon name="lucide:arrow-right" class="w-3.5 h-3.5" />
          </button>
        </div>
      </div>
    </form>
  </div>
</Card>

<script>
  // Focus search input when pressing '/' key
  document.addEventListener("astro:page-load", () => {
    document.addEventListener("keydown", (e) => {
      const target = e.target as HTMLElement;
      if (e.key === "/" && target && target.tagName !== "INPUT" && target.tagName !== "TEXTAREA") {
        e.preventDefault();
        const searchInput = document.querySelector('input[name="q"]');
        if (searchInput) {
          (searchInput as HTMLInputElement).focus();
        }
      }
    });
  });
</script>
