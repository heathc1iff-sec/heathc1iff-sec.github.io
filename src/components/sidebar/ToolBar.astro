---
import { t } from "@config";
import { Icon } from "astro-icon/components";
import Card from "../temple/Card.astro";
import ScrollToTop from "../widgets/ScrollToTop.astro";
import ThemeToggle from "../widgets/ThemeToggle.astro";
---

<Card>
  <div class="toolbar-container p-3">
    <div class="grid grid-cols-4 md:grid-cols-2 lg:grid-cols-4 gap-2">
      <a
        href="/blog/tags"
        class="flex flex-col items-center justify-center p-3 rounded-2xl bg-base-content/5 hover:bg-primary/10 hover:text-primary transition-all duration-300 group/tool"
        aria-label={t("label.tagPage")}
        title={t("label.tagPage")}
      >
        <Icon name="lucide:tag" class="w-5 h-5 transition-transform group-hover/tool:scale-110" />
      </a>

      <a
        href="/blog/categories"
        class="flex flex-col items-center justify-center p-3 rounded-2xl bg-base-content/5 hover:bg-primary/10 hover:text-primary transition-all duration-300 group/tool"
        aria-label={t("label.categoryPage")}
        title={t("label.categoryPage")}
      >
        <Icon name="lucide:folder" class="w-5 h-5 transition-transform group-hover/tool:scale-110" />
      </a>

      <a
        href="/blog/archives"
        class="flex flex-col items-center justify-center p-3 rounded-2xl bg-base-content/5 hover:bg-primary/10 hover:text-primary transition-all duration-300 group/tool"
        aria-label={t("label.archivePage")}
        title={t("label.archivePage")}
      >
        <Icon name="lucide:archive" class="w-5 h-5 transition-transform group-hover/tool:scale-110" />
      </a>

      <div class="flex items-center justify-center p-1 rounded-2xl bg-base-content/5 hover:bg-primary/10 transition-all duration-300">
        <ThemeToggle className="sidebar-theme" />
      </div>

      <slot />
    </div>
  </div>
</Card>

<!-- ScrollToTop is placed outside the Card to be fixed at the bottom of the screen -->
<ScrollToTop />
