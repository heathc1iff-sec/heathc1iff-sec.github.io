---
import type { TOCBarProps } from "@interfaces/data";
import Card from "../temple/Card.astro";

// This prop indicates whether to render the TOC
// (useful to conditionally show on certain pages)
const { headings = [], showTOC = true } = Astro.props as TOCBarProps;
---

{
  showTOC && (
    <div id="toc-container" class="mt-4 z-10 md:max-h-[calc(100vh-2rem)]">
      <Card>
        <div class="p-5">
          <div class="flex items-center gap-2 mb-4 px-1">
            <div class="w-1.5 h-5 bg-primary rounded-full"></div>
            <h3 class="text-sm font-black uppercase tracking-widest opacity-80">Contents</h3>
          </div>
          
          <nav class="toc-nav max-h-[calc(100vh-300px)] overflow-y-auto scrollbar-none relative">
            {/* Animated active indicator */}
            <div
              id="active-indicator"
              class="absolute bg-primary/10 rounded-xl opacity-0 shadow-sm pointer-events-none z-0 border-l-2 border-primary"
            />
            <ul class="space-y-1 relative z-10">
              {headings.map((heading, index) => (
                <li>
                  <a
                    href={`#heading-${index}`}
                    data-heading-slug={heading.slug}
                    data-heading-depth={heading.depth}
                    data-index={index}
                    class={`toc-link relative flex items-center py-2 px-3 rounded-xl transition-all duration-300 ${heading.depth === 1 ? "font-bold text-sm" : "text-xs font-medium opacity-70"}`}
                    style={`padding-left: ${heading.depth === 1 ? '12px' : (12 + (heading.depth - 1) * 12) + 'px'}`}
                  >
                    <span class="link-text transition-all duration-300 line-clamp-2">{heading.text}</span>
                  </a>
                </li>
              ))}
              {headings.length === 0 && (
                <li class="px-3 py-2 text-xs opacity-60">Unlock article to load table of contents.</li>
              )}
            </ul>
          </nav>
        </div>
      </Card>
    </div>
  )
}

<style>
  .toc-nav::-webkit-scrollbar {
    width: 0px;
  }

  :global(.toc-link:hover) {
    @apply bg-primary/5 text-primary opacity-100;
  }

  :global(.toc-link.active),
  :global(.toc-link.is-active) {
    @apply text-primary opacity-100;
    background: hsl(var(--p) / 0.22);
    border-left: 3px solid hsl(var(--p));
    box-shadow:
      inset 3px 0 0 hsl(var(--p)),
      0 10px 20px -18px hsl(var(--p) / 0.8);
  }

  :global(.toc-link.active .link-text),
  :global(.toc-link.is-active .link-text) {
    transform: translateX(2px);
  }
</style>

<script>
  // @ts-nocheck
  (() => {
    const host = window;
    const runtime = host.__tocRuntime || (host.__tocRuntime = {});

    const initTOC = () => {
      if (typeof host.__tocCleanup === "function") {
        host.__tocCleanup();
        delete host.__tocCleanup;
      }

      if (window.matchMedia("(max-width: 767px)").matches) return;

      const tocNav = document.querySelector(".toc-nav");
      const activeIndicator = document.getElementById("active-indicator");
      if (!tocNav || !activeIndicator) return;

      const tocLinks = Array.from(tocNav.querySelectorAll("a"));
      if (!tocLinks.length) return;

      const resolveContentRoot = () => {
        const candidates = [
          document.getElementById("post-encrypted-content"),
          document.querySelector("#post-protected-content:not(.hidden) #content"),
          document.getElementById("content"),
          document.querySelector("main .prose"),
          document.querySelector("main"),
        ];
        return candidates.find((node) => node && node.querySelector("h1, h2, h3, h4, h5, h6")) || null;
      };

      const contentRoot = resolveContentRoot();
      if (!contentRoot) return;

      const allHeadings = Array.from(contentRoot.querySelectorAll("h1, h2, h3, h4, h5, h6"));
      if (!allHeadings.length) return;

      const headingCount = Math.min(allHeadings.length, tocLinks.length);
      const headings = allHeadings.slice(0, headingCount);
      if (!headings.length) return;

      headings.forEach((heading, index) => {
        heading.id = `heading-${index}`;
      });

      tocLinks.forEach((link, index) => {
        if (index < headings.length) {
          link.setAttribute("data-index", String(index));
          link.setAttribute("href", `#heading-${index}`);
        } else {
          link.removeAttribute("data-index");
        }
      });

      let activeIndex = -1;
      let resizeTimer = null;
      let scrollRaf = null;
      let suppressScrollSyncUntil = 0;
      let headingOffsets = [];

      const isInView = (el, container) => {
        const rect = el.getBoundingClientRect();
        const crect = container.getBoundingClientRect();
        return rect.top >= crect.top && rect.bottom <= crect.bottom;
      };

      const recalcHeadingOffsets = () => {
        headingOffsets = headings.map((heading) => {
          const rect = heading.getBoundingClientRect();
          return rect.top + window.scrollY;
        });
      };

      const updateIndicator = (link, animate = true) => {
        if (!link) return;
        const headingDepth = Number.parseInt(link.getAttribute("data-heading-depth") || "1", 10);
        activeIndicator.style.transition = animate
          ? "all 0.22s cubic-bezier(0.25, 0.1, 0.25, 1)"
          : "opacity 0.22s ease-in-out";
        requestAnimationFrame(() => {
          activeIndicator.style.top = `${link.offsetTop}px`;
          activeIndicator.style.height = `${link.offsetHeight}px`;
          activeIndicator.style.opacity = "1";
          activeIndicator.style.left = `${(headingDepth - 1) * 12}px`;
          activeIndicator.style.width = `calc(100% - ${(headingDepth - 1) * 12}px)`;
        });
      };

      const setActiveIndex = (index, animate = true) => {
        if (!Number.isInteger(index) || index < 0 || index >= tocLinks.length) return;
        if (activeIndex === index) return;

        if (activeIndex >= 0 && tocLinks[activeIndex]) {
          tocLinks[activeIndex].classList.remove("active", "is-active");
        }

        const nextLink = tocLinks[index];
        nextLink.classList.add("active", "is-active");
        activeIndex = index;
        updateIndicator(nextLink, animate);

        if (!isInView(nextLink, tocNav)) {
          const top = Math.max(0, nextLink.offsetTop - tocNav.clientHeight / 2 + nextLink.offsetHeight / 2);
          tocNav.scrollTo({ top, behavior: "smooth" });
        }
      };

      const getActiveIndexByScroll = () => {
        const offset = Math.max(150, Math.min(window.innerHeight * 0.34, 320));
        const marker = window.scrollY + offset;
        if (!headingOffsets.length) return 0;

        let left = 0;
        let right = headingOffsets.length - 1;
        let result = 0;

        while (left <= right) {
          const mid = (left + right) >> 1;
          if (headingOffsets[mid] <= marker) {
            result = mid;
            left = mid + 1;
          } else {
            right = mid - 1;
          }
        }

        return result;
      };

      const syncByScroll = () => {
        if (Date.now() < suppressScrollSyncUntil) return;
        setActiveIndex(getActiveIndexByScroll());
      };

      const scheduleScrollSync = () => {
        if (scrollRaf !== null) return;
        scrollRaf = window.requestAnimationFrame(() => {
          scrollRaf = null;
          syncByScroll();
        });
      };

      const handleClick = (event) => {
        const target = event.target instanceof Element ? event.target : null;
        const link = target ? target.closest("a") : null;
        if (!link || !tocNav.contains(link)) return;

        event.preventDefault();
        const index = Number.parseInt(link.getAttribute("data-index") || "-1", 10);
        if (!Number.isInteger(index) || index < 0 || index >= headings.length) return;

        suppressScrollSyncUntil = Date.now() + 700;
        setActiveIndex(index);
        headings[index].scrollIntoView({ behavior: "smooth", block: "start" });
        history.pushState(null, "", `#${headings[index].id}`);
      };

      const handleResize = () => {
        if (resizeTimer) window.clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(() => {
          recalcHeadingOffsets();
          if (activeIndex >= 0 && tocLinks[activeIndex]) {
            updateIndicator(tocLinks[activeIndex], false);
          }
          syncByScroll();
        }, 100);
      };

      const handleHashChange = () => {
        const hash = window.location.hash.replace(/^#/, "");
        if (!hash) return;
        const index = headings.findIndex((heading) => heading.id === hash);
        if (index >= 0) setActiveIndex(index);
      };

      tocNav.addEventListener("click", handleClick);
      window.addEventListener("scroll", scheduleScrollSync, { passive: true });
      window.addEventListener("resize", handleResize, { passive: true });
      window.addEventListener("hashchange", handleHashChange);

      recalcHeadingOffsets();

      const hash = window.location.hash.replace(/^#/, "");
      const hashIndex = hash ? headings.findIndex((heading) => heading.id === hash) : -1;
      if (hashIndex >= 0) {
        setActiveIndex(hashIndex, false);
      } else {
        setActiveIndex(getActiveIndexByScroll(), false);
      }

      host.__tocCleanup = () => {
        tocNav.removeEventListener("click", handleClick);
        window.removeEventListener("scroll", scheduleScrollSync);
        window.removeEventListener("resize", handleResize);
        window.removeEventListener("hashchange", handleHashChange);
        if (resizeTimer) window.clearTimeout(resizeTimer);
        if (scrollRaf !== null) window.cancelAnimationFrame(scrollRaf);
      };
    };

    let initTimer = runtime.initTimer || null;
    const scheduleInit = (delay = 0) => {
      if (initTimer) {
        window.clearTimeout(initTimer);
      }
      initTimer = window.setTimeout(() => {
        initTimer = null;
        runtime.initTimer = null;
        initTOC();
      }, delay);
      runtime.initTimer = initTimer;
    };

    runtime.scheduleInit = scheduleInit;
    if (runtime.booted) {
      scheduleInit(0);
      return;
    }
    runtime.booted = true;

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", () => scheduleInit(0), { once: true });
    } else {
      scheduleInit(0);
    }

    document.addEventListener("astro:page-load", () => scheduleInit(0));
    window.addEventListener("post-content-updated", () => {
      scheduleInit(90);
    });
  })();
</script>
