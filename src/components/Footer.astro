---
import { USER_FOOTER_SOCIAL_ICONS, USER_NAME, USER_SITE } from "@config";
import { Icon } from "astro-icon/components";
---

<footer class="frosti-card p-10 mt-12 mb-8 flex flex-col md:flex-row justify-between items-center gap-8">
  <aside class="flex flex-col items-center md:items-start text-center md:text-left gap-4">
    <div class="p-3 bg-primary/10 rounded-2xl w-fit">
      <Icon name="lucide:terminal" class="w-8 h-8 text-primary" />
    </div>
    <div>
      <p class="text-sm font-bold opacity-80 mb-1">
        Powered by <a href="https://github.com/EveSunMaple/Frosti" target="_blank" class="text-primary hover:underline transition-all">Frosti</a>
      </p>
      <p class="text-xs opacity-40 font-medium uppercase tracking-widest">
        Copyright © {new Date().getFullYear()} {USER_NAME} · Built with Astro
      </p>
    </div>
  </aside>
  
  <nav class="flex flex-col items-center md:items-end gap-4">
    <div class="flex gap-3">
      {
        USER_FOOTER_SOCIAL_ICONS.map((icon) => (
          <a 
            href={icon.href} 
            aria-label={icon.ariaLabel}
            target="_blank"
            class="p-2 rounded-lg bg-base-content/5 hover:bg-primary/10 hover:text-primary transition-all duration-300"
            title={icon.title}
          >
            <Icon name={icon.svg} class="w-5 h-5" />
          </a>
        ))
      }
      <a 
        href="/rss.xml" 
        aria-label="RSS Feed"
        class="p-2 rounded-lg bg-base-content/5 hover:bg-orange-500/10 hover:text-orange-500 transition-all duration-300"
      >
        <Icon name="ri:rss-line" class="w-5 h-5" />
      </a>
    </div>
    <p class="text-[10px] font-black opacity-20 uppercase tracking-[0.3em]">Stay Creative</p>
  </nav>
</footer>
