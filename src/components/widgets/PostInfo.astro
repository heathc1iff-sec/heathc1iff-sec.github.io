---
import { t } from "@config";
import type { PostData } from "@interfaces/data";
import { Icon } from "astro-icon/components";

const { pubDate, badge, word, time } = Astro.props as PostData;
---

<div class="flex flex-wrap items-center gap-4 text-xs font-bold uppercase tracking-widest text-base-content/40">
  {
    pubDate && (
      <span class="flex items-center gap-1.5 hover:text-primary transition-colors">
        <Icon name="lucide:calendar-days" class="h-3.5 w-3.5" />
        <span>{pubDate}</span>
      </span>
    )
  }
  {
    badge && (
      <span class="flex items-center gap-1.5 px-2 py-0.5 rounded bg-primary/10 text-primary">
        <Icon name="lucide:hash" class="h-3 w-3" />
        <span>{badge}</span>
      </span>
    )
  }
  <span class="flex items-center gap-1.5 ml-auto sm:ml-0">
    <Icon name="lucide:timer" class="h-3.5 w-3.5" />
    <span>{word} / {time}m</span>
  </span>
</div>
