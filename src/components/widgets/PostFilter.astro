---
import { t } from "@config";
import type { PostData } from "@interfaces/data";
import { Icon } from "astro-icon/components";

const { categories = [], tags = [] } = Astro.props as PostData;
---

<div class="post-filter-row">
  {
    categories.map((category) => (
      <a href={`/blog/category/${encodeURIComponent(category)}`} class="btn btn-xs btn-category post-filter-chip">
        <Icon name="lucide:folder" class="w-4 h-4" />
        <span>{category}</span>
      </a>
    ))
  }
  {
    tags.map((tag) => (
      <a href={`/blog/tag/${encodeURIComponent(tag)}`} class="btn btn-xs btn-tag post-filter-chip">
        <Icon name="lucide:tag" class="w-4 h-4" />
        <span>{tag}</span>
      </a>
    ))
  }
  {
    categories.length === 0 && (
      <span class="btn btn-xs btn-ghost opacity-60 gap-1 post-filter-empty">
        <Icon name="lucide:folder" class="w-4 h-4" />
        <span>{t("label.noCategory")}</span>
      </span>
    )
  }
  {
    tags.length === 0 && (
      <span class="btn btn-xs btn-ghost opacity-60 gap-1 post-filter-empty">
        <Icon name="lucide:tag" class="w-4 h-4" />
        <span>{t("label.noTag")}</span>
      </span>
    )
  }
</div>
