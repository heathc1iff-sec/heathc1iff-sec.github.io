---
import { ClientRouter } from "astro:transitions";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import Navbar from "@components/Navbar.astro";
import Sidebar from "@components/Sidebar.astro";
import MobileTOC from "@components/widgets/MobileTOC.astro";
import {
  SITE_DESCRIPTION,
  SITE_FAVICON,
  SITE_LANGUAGE,
  SITE_TAB,
  SITE_THEME,
} from "@config";
import ElementCrossing from "astro-vtbot/components/ElementCrossing.astro";
import PointerOnNavigation from "astro-vtbot/components/PointerOnNavigation.astro";

const {
  title,
  image,
  description = SITE_DESCRIPTION,
  headings = [],
  showTOC = false,
  isIndexed = false,
  pageType = "default",
} = Astro.props;

const currentPathname = Astro.url.pathname;
const isBlogRoute =
  currentPathname === "/blog" || currentPathname.startsWith("/blog/");
---

<!doctype html>
<html
  lang={SITE_LANGUAGE}
  class="bg-base-300"
  data-theme={SITE_THEME.light}
  data-theme-type="light"
  data-page-type={pageType}
  data-page-path={currentPathname}
  data-performance-mode={isBlogRoute ? "lite" : "normal"}
>
  <head>
    <ClientRouter />
    {!isBlogRoute && <ElementCrossing />}
    {!isBlogRoute && <PointerOnNavigation />}
    <Header title={title} description={description} favicon={SITE_FAVICON} image={image} />

    <script define:vars={{ SITE_THEME }} is:inline>
      (function () {
        const DAY_START_HOUR = 7;
        const NIGHT_START_HOUR = 19;
        const THEME_MODE_KEY = "theme-mode";

        const isValidTheme = (value) => value === SITE_THEME.light || value === SITE_THEME.dark;

        const getClockTheme = () => {
          const hour = new Date().getHours();
          return hour >= DAY_START_HOUR && hour < NIGHT_START_HOUR
            ? SITE_THEME.light
            : SITE_THEME.dark;
        };

        const applyTheme = (theme, source) => {
          document.documentElement.setAttribute("data-theme", theme);
          document.documentElement.setAttribute(
            "data-theme-type",
            theme === SITE_THEME.dark ? "dark" : "light",
          );
          document.documentElement.setAttribute("data-theme-source", source);
        };

        const resolveTheme = () => {
          const mode = localStorage.getItem(THEME_MODE_KEY);
          const storedTheme = localStorage.getItem("theme");

          if (mode === "manual" && isValidTheme(storedTheme)) {
            return { theme: storedTheme, source: "manual" };
          }

          // Migration: old versions stored "theme" by default.
          // Treat missing/invalid mode as clock-auto behavior.
          return { theme: getClockTheme(), source: "clock" };
        };

        const applyResolvedTheme = () => {
          const { theme, source } = resolveTheme();
          applyTheme(theme, source);
        };

        window.__applyResolvedTheme = applyResolvedTheme;
        applyResolvedTheme();

        if (!window.__themeClockTimerStarted) {
          window.__themeClockTimerStarted = true;
          window.setInterval(() => {
            const mode = localStorage.getItem(THEME_MODE_KEY);
            if (mode === "manual") return;

            const nextTheme = getClockTheme();
            if (document.documentElement.getAttribute("data-theme") !== nextTheme) {
              applyTheme(nextTheme, "clock");
            }
          }, 60 * 1000);
        }
      })();
    </script>
  </head>

  <body class="flex flex-col min-h-screen">
    {
      isBlogRoute ? (
        <div class="theme-background theme-background--lite" aria-hidden="true">
          <div class="theme-background__gradient"></div>
          <div class="theme-background__stars theme-background__stars--lite"></div>
          <div class="theme-background__moon"></div>
          <div class="theme-background__vignette"></div>
        </div>
      ) : (
        <div class="theme-background" aria-hidden="true">
          <div class="theme-background__gradient"></div>
          <!-- Animated Blobs for Light Mode -->
          <div class="glass-blobs" aria-hidden="true">
            <div class="glass-blob glass-blob--1"></div>
            <div class="glass-blob glass-blob--2"></div>
            <div class="glass-blob glass-blob--3"></div>
            <div class="glass-blob glass-blob--4"></div>
          </div>
          <div class="theme-background__mesh"></div>
          <div class="theme-background__aurora theme-background__aurora--a"></div>
          <div class="theme-background__aurora theme-background__aurora--b"></div>
          <div class="theme-background__sun"></div>
          <div class="theme-background__glow theme-background__glow--a"></div>
          <div class="theme-background__glow theme-background__glow--b"></div>
          <div class="theme-background__stars" data-starfield></div>
          <div class="theme-background__particles"></div>
          <span class="theme-background__meteor theme-background__meteor--a"></span>
          <span class="theme-background__meteor theme-background__meteor--b"></span>
          <span class="theme-background__meteor theme-background__meteor--c"></span>
          <span class="theme-background__meteor theme-background__meteor--d"></span>
          <div class="theme-background__grain"></div>
          <div class="theme-background__vignette"></div>
        </div>
      )
    }

    <div class="site-content-layer">
      <Navbar />

      <div class="site-shell">
        <div class="layout-grid">
          <main class="layout-main bg-transparent">
            <div
              class="layout-main__content"
              {...isIndexed ? { "data-pagefind-body": true } : {}}
            >
              <slot />
            </div>
            <Footer />
          </main>
          <aside class="layout-sidebar bg-transparent">
            <Sidebar headings={headings} showTOC={showTOC} />
            <slot name="sidebar" />
          </aside>
        </div>
      </div>

      <MobileTOC headings={headings} showTOC={showTOC} />

      <script>
        document.addEventListener("astro:after-swap", () => {
          if (typeof (window as any).__applyResolvedTheme === "function") {
            (window as any).__applyResolvedTheme();
          }
        });
        // Copy button handler with delegation
        const setupCopyButtons = () => {
          if ((window as any).__copyHandlerBound) return;
          (window as any).__copyHandlerBound = true;

          document.addEventListener("click", async (event) => {
            const button = (event.target as HTMLElement)?.closest?.(".btn-copy");
            if (!button) return;

            const codeBlock = button.closest(".frosti-code");
            const codeElement = codeBlock?.querySelector?.("code");
            const copyText = codeElement?.textContent ?? "";
            if (!copyText.trim()) return;

            const copyIcon = button.querySelector(".frosti-code-toolbar-copy-icon");
            const successIcon = button.querySelector(".frosti-code-toolbar-copy-success");

            try {
              await navigator.clipboard.writeText(copyText);
              copyIcon?.classList.add("hidden");
              successIcon?.classList.remove("hidden");
              button.classList.add("copy-success");
              setTimeout(() => {
                copyIcon?.classList.remove("hidden");
                successIcon?.classList.add("hidden");
                button.classList.remove("copy-success");
              }, 2000);
            } catch (err) {
              console.error("Failed to copy:", err);
            }
          });
        };

        // Starfield generator
        const setupStarfield = () => {
          const perfMode = document.documentElement.getAttribute("data-performance-mode");
          if (perfMode === "lite") return;

          const field = document.querySelector("[data-starfield]") as HTMLElement;
          if (!field || field.dataset.starReady === "1") return;
          field.dataset.starReady = "1";

          const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          const reducedData = window.matchMedia("(prefers-reduced-data: reduce)").matches;
          const isBlogPost = document.documentElement.getAttribute("data-page-type") === "blog-post";
          const count = reducedData
            ? 14
            : reducedMotion
              ? isBlogPost
                ? 22
                : 28
              : isBlogPost
                ? window.innerWidth < 768
                  ? 24
                  : 34
                : window.innerWidth < 768
                  ? 40
                  : 62;

          const fragment = document.createDocumentFragment();
          for (let i = 0; i < count; i += 1) {
            const star = document.createElement("span");
            star.className = "theme-background__star";

            const size =
              Math.random() < 0.1 ? 1.7 + Math.random() * 1.2 : 0.68 + Math.random() * 0.95;
            star.style.width = `${size.toFixed(2)}px`;
            star.style.height = `${size.toFixed(2)}px`;
            star.style.left = `${(Math.random() * 100).toFixed(3)}%`;
            star.style.top = `${(Math.random() * 78).toFixed(3)}%`;
            star.style.opacity = `${(0.24 + Math.random() * 0.62).toFixed(3)}`;
            star.style.setProperty("--twinkle-duration", `${(5.6 + Math.random() * 9.8).toFixed(2)}s`);
            star.style.setProperty("--twinkle-delay", `${(-Math.random() * 9.5).toFixed(2)}s`);
            star.style.setProperty("--star-scale", (0.82 + Math.random() * 0.44).toFixed(3));

            fragment.appendChild(star);
          }

          field.appendChild(fragment);
        };

        // Initialize on page load and after-swap
        const init = () => {
          setupCopyButtons();
          // Use requestIdleCallback if available for non-critical starfield
          if ('requestIdleCallback' in window) {
            window.requestIdleCallback(() => setupStarfield());
          } else {
            setTimeout(setupStarfield, 100);
          }
        };

        document.addEventListener("astro:page-load", init);
      </script>

      <style is:inline>
        .btn-copy {
          position: relative;
          overflow: hidden;
        }
        .copy-success {
          animation: pulse 0.5s ease-in-out;
        }
        .frosti-code-toolbar-copy-success svg {
          color: #10b981;
        }
        @keyframes pulse {
          0% {
            transform: scale(1);
          }
          50% {
            transform: scale(1.1);
          }
          100% {
            transform: scale(1);
          }
        }
      </style>
    </div>
  </body>
</html>
