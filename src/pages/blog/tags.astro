---
import "@/styles/global.scss";
import BaseCard from "@components/BaseCard.astro";
import { t } from "@config";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getAllPosts, getTagsWithCount } from "@utils/blogUtils";
import { Icon } from "astro-icon/components";

const allPosts = await getAllPosts();
const tagCounts = getTagsWithCount(allPosts);
const tagEntries = Array.from(tagCounts.entries()).sort((a, b) => b[1] - a[1]);

const COLORS = [
  "#818cf8",
  "#2dd4bf",
  "#fb7185",
  "#fbbf24",
  "#a78bfa",
  "#38bdf8",
  "#4ade80",
  "#f472b6",
  "#f87171",
  "#22d3ee",
];

const totalNodes = tagEntries.length;
const nodes = tagEntries.map((entry, index) => {
  const [tag, count] = entry;
  const color = COLORS[index % COLORS.length];

  let zone: "inner" | "mid" | "outer";
  let orbitBase: number;
  let sizeClass: string;

  if (index < totalNodes * 0.15) {
    zone = "inner";
    orbitBase = 220;
    sizeClass = "text-base font-black";
  } else if (index < totalNodes * 0.45) {
    zone = "mid";
    orbitBase = 360;
    sizeClass = "text-sm font-bold";
  } else {
    zone = "outer";
    orbitBase = 520;
    sizeClass = "text-xs font-semibold opacity-70";
  }

  return {
    id: `node-${index}`,
    tag,
    count,
    color,
    zone,
    sizeClass,
    orbit: orbitBase,
    href: `/blog/tag/${encodeURIComponent(tag)}`,
  };
});
---

<BaseLayout title="Brain Map" description={t("label.tagsPageDescription")}>
  <div class="space-y-12 py-6">
    <section>
      <BaseCard>
        <div class="relative p-4 flex flex-col min-h-[750px]">
          <div class="flex justify-between items-center mb-6 z-50">
            <div class="flex items-center gap-3">
              <div class="p-2 bg-primary/10 rounded-lg">
                <Icon name="lucide:brain-circuit" class="w-6 h-6 text-primary" />
              </div>
              <h1 class="text-xl font-black tracking-tight">Brain Map</h1>
            </div>
            <button id="reset-system" class="btn btn-sm btn-ghost gap-2 rounded-full border border-base-content/10">
              <Icon name="lucide:refresh-ccw" class="w-3.5 h-3.5" />
              <span class="text-[10px] font-bold">RESET</span>
            </button>
          </div>

          <div class="flex-1 relative overflow-hidden rounded-xl bg-base-200/20 shadow-inner" id="viewport" style="cursor: grab;">
            <div id="star-field" class="absolute inset-0 pointer-events-none opacity-20"></div>
            <div id="world" class="absolute inset-0 transform-origin-center">
              <div id="nodes-layer" class="absolute inset-0">
                {nodes.map((node) => (
                  <a href={node.href} class="planet-node" data-id={node.id} style={`--node-clr: ${node.color};`}>
                    <div class="glass-pill-lite">
                      <div class="indicator-bar"></div>
                      <span class={`name ${node.sizeClass}`}>{node.tag}</span>
                      <span class="count">{node.count}</span>
                    </div>
                  </a>
                ))}
              </div>

              <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-40 pointer-events-none">
                <div class="center-aura"></div>
                <Icon name="mdi:brain" class="w-14 h-14 text-primary drop-shadow-[0_0_10px_oklch(var(--p)/0.5)]" />
              </div>
            </div>
          </div>
        </div>
      </BaseCard>
    </section>

    <section>
      <BaseCard>
        <div class="relative p-8 flex flex-col">
          <div class="flex items-center gap-4 mb-8">
            <h2 class="text-sm font-black uppercase tracking-widest opacity-40">Knowledge Index</h2>
            <div class="h-px flex-1 bg-base-content/5"></div>
          </div>
          <div class="flex flex-wrap justify-center gap-4">
            {tagEntries.map(([tag, count], index) => {
              const color = COLORS[index % COLORS.length];
              return (
                <a href={`/blog/tag/${encodeURIComponent(tag)}`} class="glass-index-tile group" style={`--tile-clr: ${color}`}>
                  <div class="tile-bar"></div>
                  <span class="tile-label">{tag}</span>
                  <span class="tile-val">{count}</span>
                </a>
              );
            })}
          </div>
        </div>
      </BaseCard>
    </section>
  </div>
</BaseLayout>

<style is:global>
  .planet-node { position: absolute; z-index: 30; text-decoration: none; transition: z-index 0s; }
  .planet-node:hover { z-index: 1000; }
  .glass-pill-lite, .glass-index-tile { @apply backdrop-blur-[10px] border border-white/10; background: rgba(255, 255, 255, 0.03); box-shadow: inset 0 1px 1px rgba(255,255,255,0.05); }
  [data-theme-type="light"] .glass-pill-lite, [data-theme-type="light"] .glass-index-tile { background: rgba(0, 0, 0, 0.02); border-color: rgba(0, 0, 0, 0.05); }
  .glass-pill-lite { @apply flex items-center gap-2 px-4 py-2 rounded-xl; color: white; white-space: nowrap; transition: transform 0.3s, border-color 0.3s; }
  [data-theme-type="light"] .glass-pill-lite { color: #1e293b; }
  .indicator-bar { width: 3px; height: 12px; background: var(--node-clr); border-radius: 4px; box-shadow: 0 0 10px var(--node-clr); }
  .glass-pill-lite .count { font-size: 10px; font-weight: 900; color: var(--node-clr); opacity: 0.5; margin-left: 2px; }
  .planet-node:hover .glass-pill-lite { transform: scale(1.05) translateY(-2px); border-color: var(--node-clr); }
  .center-aura { position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); width: 150px; height: 150px; background: radial-gradient(circle, oklch(var(--p) / 0.15) 0%, transparent 70%); }
  .glass-index-tile { @apply flex items-center gap-3 px-5 py-3 rounded-xl no-underline transition-all duration-300; }
  .glass-index-tile:hover { transform: translateY(-4px); border-color: var(--tile-clr); }
  .tile-bar { width: 4px; height: 14px; background: var(--tile-clr); border-radius: 4px; }
  .tile-label { color: white; font-weight: 700; font-size: 14px; opacity: 0.8; }
  [data-theme-type="light"] .tile-label { color: #1e293b; }
  .tile-val { font-weight: 900; color: var(--tile-clr); font-size: 11px; opacity: 0.5; }
</style>

<script is:inline define:vars={{ nodes }} data-astro-rerun>
  (function () {
    const CLEANUP_KEY = "__brainMapCleanup";
    const previousCleanup = window[CLEANUP_KEY];
    if (typeof previousCleanup === "function") {
      previousCleanup();
    }

    const viewport = document.getElementById("viewport");
    const world = document.getElementById("world");
    const starField = document.getElementById("star-field");
    const resetBtn = document.getElementById("reset-system");
    if (!viewport || !world || !starField || !resetBtn) return;

    const cleanupFns = [];
    const on = (target, type, handler, options) => {
      target.addEventListener(type, handler, options);
      cleanupFns.push(() => target.removeEventListener(type, handler, options));
    };

    let width = 0;
    let height = 0;
    let scale = 1;
    let panX = 0;
    let panY = 0;
    let frameId = 0;
    let running = true;
    let hasStarted = false;

    const DAMPING = 0.45;
    const MIN_DIST = 95;
    const speeds = { inner: 0.0005, mid: 0.0003, outer: 0.0002 };

    const zoneTotals = { inner: 0, mid: 0, outer: 0 };
    nodes.forEach((node) => {
      zoneTotals[node.zone] += 1;
    });
    const zoneCursor = { inner: 0, mid: 0, outer: 0 };

    const nodeData = nodes
      .map((node) => {
        const groupLen = Math.max(zoneTotals[node.zone], 1);
        const groupIdx = zoneCursor[node.zone]++;
        const angle = (groupIdx / groupLen) * Math.PI * 2;
        const el = viewport.querySelector(`[data-id="${node.id}"]`);
        return {
          ...node,
          angle,
          x: Math.cos(angle) * node.orbit,
          y: Math.sin(angle) * node.orbit,
          vx: 0,
          vy: 0,
          isDragging: false,
          el,
        };
      })
      .filter((node) => node.el);

    const nodeByElement = new Map(nodeData.map((node) => [node.el, node]));

    const updateViewportMetrics = () => {
      const rect = viewport.getBoundingClientRect();
      width = rect.width;
      height = rect.height;
      return rect;
    };

    const applyWorldTransform = () => {
      world.style.transform = `translate(${panX}px, ${panY}px) scale(${scale})`;
    };

    const solve = () => {
      for (let cycle = 0; cycle < 2; cycle += 1) {
        for (let i = 0; i < nodeData.length; i += 1) {
          const a = nodeData[i];
          if (a.isDragging) continue;

          for (let j = i + 1; j < nodeData.length; j += 1) {
            const b = nodeData[j];
            const dx = b.x - a.x;
            const dy = b.y - a.y;
            const dist = Math.hypot(dx, dy) || 1;
            if (dist < MIN_DIST) {
              const push = (MIN_DIST - dist) * 0.05;
              const ox = (dx / dist) * push;
              const oy = (dy / dist) * push;
              a.x -= ox;
              a.y -= oy;
              b.x += ox;
              b.y += oy;
            }
          }

          const radius = Math.hypot(a.x, a.y) || 1;
          a.x = (a.x / radius) * a.orbit;
          a.y = (a.y / radius) * a.orbit;
        }
      }
    };

    const tick = () => {
      if (!running) return;
      const cx = width / 2;
      const cy = height / 2;

      nodeData.forEach((node) => {
        if (node.isDragging) return;
        node.angle += speeds[node.zone];
        const tx = Math.cos(node.angle) * node.orbit;
        const ty = Math.sin(node.angle) * node.orbit;
        node.vx = (node.vx + (tx - node.x) * 0.02) * DAMPING;
        node.vy = (node.vy + (ty - node.y) * 0.02) * DAMPING;
        node.x += node.vx;
        node.y += node.vy;
      });

      solve();
      nodeData.forEach((node) => {
        node.el.style.transform = `translate3d(${cx + node.x}px, ${cy + node.y}px, 0) translate(-50%, -50%)`;
      });

      frameId = requestAnimationFrame(tick);
    };

    const buildStarField = () => {
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const starCount = prefersReducedMotion ? 60 : 100;
      const fragment = document.createDocumentFragment();

      for (let i = 0; i < starCount; i += 1) {
        const star = document.createElement("span");
        star.style.position = "absolute";
        star.style.left = `${Math.random() * 100}%`;
        star.style.top = `${Math.random() * 100}%`;
        star.style.width = "1.5px";
        star.style.height = "1.5px";
        star.style.background = "white";
        star.style.opacity = "0.3";
        star.style.borderRadius = "50%";
        fragment.appendChild(star);
      }

      starField.replaceChildren(fragment);
    };

    const positionNodesImmediately = () => {
      const cx = width / 2;
      const cy = height / 2;

      nodeData.forEach((node) => {
        node.el.style.transform = `translate3d(${cx + node.x}px, ${cy + node.y}px, 0) translate(-50%, -50%)`;
      });
    };

    const bootstrapLayout = () => {
      if (hasStarted) return true;

      const rect = updateViewportMetrics();
      if (rect.width < 40 || rect.height < 40) {
        return false;
      }

      applyWorldTransform();
      for (let i = 0; i < 200; i += 1) solve();
      buildStarField();
      positionNodesImmediately();
      frameId = requestAnimationFrame(tick);
      hasStarted = true;
      return true;
    };

    const waitForStableViewport = (attempt = 0) => {
      if (bootstrapLayout()) return;
      if (attempt > 24) {
        updateViewportMetrics();
        positionNodesImmediately();
        frameId = requestAnimationFrame(tick);
        hasStarted = true;
        return;
      }

      requestAnimationFrame(() => waitForStableViewport(attempt + 1));
    };

    let isPanning = false;
    let panStartX = 0;
    let panStartY = 0;
    let activeNode = null;
    let movedWhileDragging = false;
    let dragStartX = 0;
    let dragStartY = 0;

    const handlePointerDown = (event) => {
      const element = event.target instanceof Element ? event.target.closest(".planet-node") : null;
      const node = element ? nodeByElement.get(element) : null;

      if (node) {
        activeNode = node;
        activeNode.isDragging = true;
        activeNode.el.style.zIndex = "1000";
        movedWhileDragging = false;
        dragStartX = event.clientX;
        dragStartY = event.clientY;
        return;
      }

      isPanning = true;
      panStartX = event.clientX - panX;
      panStartY = event.clientY - panY;
      viewport.style.cursor = "grabbing";
    };

    const handlePointerMove = (event) => {
      if (activeNode) {
        const dx = event.clientX - dragStartX;
        const dy = event.clientY - dragStartY;
        if (Math.hypot(dx, dy) > 3) {
          movedWhileDragging = true;
        }

        const rect = viewport.getBoundingClientRect();
        activeNode.x = (event.clientX - rect.left - panX) / scale - width / 2;
        activeNode.y = (event.clientY - rect.top - panY) / scale - height / 2;
        return;
      }

      if (!isPanning) return;
      panX = event.clientX - panStartX;
      panY = event.clientY - panStartY;
      applyWorldTransform();
    };

    const handlePointerUp = () => {
      if (activeNode) {
        activeNode.isDragging = false;
        activeNode.el.style.zIndex = "30";
        activeNode.angle = Math.atan2(activeNode.y, activeNode.x);
        activeNode.orbit = Math.hypot(activeNode.x, activeNode.y);
        activeNode = null;

        if (movedWhileDragging) {
          const suppressClick = (clickEvent) => {
            clickEvent.preventDefault();
            clickEvent.stopPropagation();
            window.removeEventListener("click", suppressClick, true);
          };
          window.addEventListener("click", suppressClick, true);
        }
      }

      isPanning = false;
      viewport.style.cursor = "grab";
    };

    const handleWheel = (event) => {
      event.preventDefault();
      const zoom = event.deltaY > 0 ? 0.95 : 1.05;
      scale = Math.min(Math.max(0.3, scale * zoom), 3);
      applyWorldTransform();
    };

    const handleReset = () => {
      panX = 0;
      panY = 0;
      scale = 1;
      applyWorldTransform();
      positionNodesImmediately();
    };

    const handleVisibilityChange = () => {
      if (document.hidden) {
        running = false;
        cancelAnimationFrame(frameId);
      } else if (!running) {
        running = true;
        if (hasStarted) {
          frameId = requestAnimationFrame(tick);
        } else {
          waitForStableViewport();
        }
      }
    };

    const cleanup = () => {
      running = false;
      cancelAnimationFrame(frameId);
      cleanupFns.splice(0).forEach((fn) => fn());
      if (window[CLEANUP_KEY] === cleanup) {
        window[CLEANUP_KEY] = null;
      }
    };

    on(viewport, "pointerdown", handlePointerDown);
    on(window, "pointermove", handlePointerMove, { passive: true });
    on(window, "pointerup", handlePointerUp);
    on(window, "pointercancel", handlePointerUp);
    on(viewport, "wheel", handleWheel, { passive: false });
    on(resetBtn, "click", handleReset);
    on(window, "resize", () => {
      updateViewportMetrics();
      positionNodesImmediately();
    });
    on(document, "visibilitychange", handleVisibilityChange);
    on(document, "astro:before-swap", cleanup, { once: true });
    on(window, "beforeunload", cleanup, { once: true });

    waitForStableViewport();
    window[CLEANUP_KEY] = cleanup;
  })();
</script>
