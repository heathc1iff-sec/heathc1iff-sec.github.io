---
import BaseCard from "@components/BaseCard.astro";
import { t } from "@config";
import BaseLayout from "@layouts/BaseLayout.astro";
import {
  getAllPosts,
  getTagsWithCount,
} from "@utils/blogUtils";
import { Icon } from "astro-icon/components";

const allPosts = await getAllPosts();
const tagCounts = getTagsWithCount(allPosts);
const tagEntries = Array.from(tagCounts.entries()).sort((a, b) => b[1] - a[1]);
const maxCount = tagEntries.length > 0 ? tagEntries[0][1] : 0;

const COLORS = [
  '#818cf8', '#2dd4bf', '#fb7185', '#fbbf24', '#a78bfa', 
  '#38bdf8', '#4ade80', '#f472b6', '#f87171', '#22d3ee'
];

const totalNodes = tagEntries.length;
const nodes = tagEntries.map((entry, index) => {
  const [tag, count] = entry;
  const color = COLORS[index % COLORS.length];
  let zone, orbitBase, sizeClass;
  if (index < totalNodes * 0.15) {
    zone = 'inner'; orbitBase = 220; sizeClass = 'text-base font-black';
  } else if (index < totalNodes * 0.45) {
    zone = 'mid'; orbitBase = 360; sizeClass = 'text-sm font-bold';
  } else {
    zone = 'outer'; orbitBase = 520; sizeClass = 'text-xs font-semibold opacity-70';
  }
  return { id: `node-${index}`, tag, count, color, zone, sizeClass, orbit: orbitBase, href: `/blog/tag/${encodeURIComponent(tag)}` };
});
---

<BaseLayout title="Brain Map" description={t("label.tagsPageDescription")}>
  <div class="space-y-12 py-6">
    
    <!-- 脑图展示区 (满足 8/9 条) -->
    <section>
      <BaseCard>
        <div class="relative p-4 flex flex-col min-h-[750px]">
          <div class="flex justify-between items-center mb-6 z-50">
            <div class="flex items-center gap-3">
              <div class="p-2 bg-primary/10 rounded-lg">
                <Icon name="lucide:brain-circuit" class="w-6 h-6 text-primary" />
              </div>
              <h1 class="text-xl font-black tracking-tight">Brain Map</h1>
            </div>
            <button id="reset-system" class="btn btn-sm btn-ghost gap-2 rounded-full border border-base-content/10">
              <Icon name="lucide:refresh-ccw" class="w-3.5 h-3.5" />
              <span class="text-[10px] font-bold">RESET</span>
            </button>
          </div>

          <div class="flex-1 relative overflow-hidden rounded-xl bg-base-200/20 shadow-inner" id="viewport" style="cursor: grab;">
            <div id="star-field" class="absolute inset-0 pointer-events-none opacity-20"></div>
            <div id="world" class="absolute inset-0 transform-origin-center">
              <div id="nodes-layer" class="absolute inset-0">
                {nodes.map((node) => (
                  <a href={node.href} class="planet-node" data-id={node.id} style={`--node-clr: ${node.color};`}>
                    <div class="glass-pill-lite">
                      <div class="indicator-bar"></div>
                      <span class={`name ${node.sizeClass}`}>{node.tag}</span>
                      <span class="count">{node.count}</span>
                    </div>
                  </a>
                ))}
              </div>
              <!-- 中心大脑 (满足 5/6 条) -->
              <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-40 pointer-events-none">
                <div class="center-aura"></div>
                <Icon name="mdi:brain" class="w-14 h-14 text-primary drop-shadow-[0_0_10px_oklch(var(--p)/0.5)]" />
              </div>
            </div>
          </div>
        </div>
      </BaseCard>
    </section>

    <!-- 索引区 (满足 9 条) -->
    <section>
      <BaseCard>
        <div class="relative p-8 flex flex-col">
          <div class="flex items-center gap-4 mb-8">
            <h2 class="text-sm font-black uppercase tracking-widest opacity-40">Knowledge Index</h2>
            <div class="h-px flex-1 bg-base-content/5"></div>
          </div>
          <div class="flex flex-wrap justify-center gap-4">
            {tagEntries.map(([tag, count], index) => {
              const color = COLORS[index % COLORS.length];
              return (
                <a href={`/blog/tag/${encodeURIComponent(tag)}`} class="glass-index-tile group" style={`--tile-clr: ${color}`}>
                  <div class="tile-bar"></div>
                  <span class="tile-label">{tag}</span>
                  <span class="tile-val">{count}</span>
                </a>
              );
            })}
          </div>
        </div>
      </BaseCard>
    </section>
  </div>
</BaseLayout>

<style is:global>
  .planet-node { position: absolute; z-index: 30; text-decoration: none; transition: z-index 0s; }
  .planet-node:hover { z-index: 1000; }
  .glass-pill-lite, .glass-index-tile { @apply backdrop-blur-[10px] border border-white/10; background: rgba(255, 255, 255, 0.03); box-shadow: inset 0 1px 1px rgba(255,255,255,0.05); }
  [data-theme-type="light"] .glass-pill-lite, [data-theme-type="light"] .glass-index-tile { background: rgba(0, 0, 0, 0.02); border-color: rgba(0, 0, 0, 0.05); }
  .glass-pill-lite { @apply flex items-center gap-2 px-4 py-2 rounded-xl; color: white; white-space: nowrap; transition: transform 0.3s, border-color 0.3s; }
  [data-theme-type="light"] .glass-pill-lite { color: #1e293b; }
  .indicator-bar { width: 3px; height: 12px; background: var(--node-clr); border-radius: 4px; box-shadow: 0 0 10px var(--node-clr); }
  .glass-pill-lite .count { font-size: 10px; font-weight: 900; color: var(--node-clr); opacity: 0.5; margin-left: 2px; }
  .planet-node:hover .glass-pill-lite { transform: scale(1.05) translateY(-2px); border-color: var(--node-clr); }
  .center-aura { position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); width: 150px; height: 150px; background: radial-gradient(circle, oklch(var(--p) / 0.15) 0%, transparent 70%); }
  .glass-index-tile { @apply flex items-center gap-3 px-5 py-3 rounded-xl no-underline transition-all duration-300; }
  .glass-index-tile:hover { transform: translateY(-4px); border-color: var(--tile-clr); }
  .tile-bar { width: 4px; height: 14px; background: var(--tile-clr); border-radius: 4px; }
  .tile-label { color: white; font-weight: 700; font-size: 14px; opacity: 0.8; }
  [data-theme-type="light"] .tile-label { color: #1e293b; }
  .tile-val { font-weight: 900; color: var(--tile-clr); font-size: 11px; opacity: 0.5; }
</style>

<script is:inline define:vars={{ nodes }}>
  (function() {
    const viewport = document.getElementById('viewport');
    const world = document.getElementById('world');
    const starField = document.getElementById('star-field');
    const resetBtn = document.getElementById('reset-system');
    if (!viewport || !world) return;

    let width, height;
    let scale = 1; let panX = 0; let panY = 0;
    const DAMPING = 0.45; // 极高阻尼
    const MIN_DIST = 95; // 安全半径

    const nodeData = nodes.map((n, i) => {
      const groupLen = nodes.filter(x => x.zone === n.zone).length;
      const groupIdx = nodes.filter(x => x.zone === n.zone).indexOf(n);
      const angle = (groupIdx / groupLen) * Math.PI * 2;
      return { ...n, angle, x: Math.cos(angle)*n.orbit, y: Math.sin(angle)*n.orbit, vx: 0, vy: 0, isDragging: false, el: document.querySelector(`[data-id="${n.id}"]`) };
    });

    function solve() {
      for (let k = 0; k < 2; k++) {
        nodeData.forEach((a, i) => {
          if (a.isDragging) return;
          nodeData.forEach((b, j) => {
            if (i >= j) return;
            const dx = b.x - a.x; const dy = b.y - a.y;
            const d = Math.hypot(dx, dy) || 1;
            if (d < MIN_DIST) {
              const push = (MIN_DIST - d) * 0.05;
              const ox = (dx / d) * push; const oy = (dy / d) * push;
              a.x -= ox; a.y -= oy; b.x += ox; b.y += oy;
            }
          });
          const r = Math.hypot(a.x, a.y) || 1;
          a.x = (a.x / r) * a.orbit; a.y = (a.y / r) * a.orbit;
        });
      }
    }

    function tick() {
      const cx = width / 2; const cy = height / 2;
      nodeData.forEach(a => {
        if (a.isDragging) return;
        a.angle += speeds[a.zone];
        const tx = Math.cos(a.angle) * a.orbit; const ty = Math.sin(a.angle) * a.orbit;
        a.vx = (a.vx + (tx - a.x) * 0.02) * DAMPING;
        a.vy = (a.vy + (ty - a.y) * 0.02) * DAMPING;
        a.x += a.vx; a.y += a.vy;
      });
      solve();
      nodeData.forEach(n => {
        if (n.el) n.el.style.transform = `translate3d(${cx + n.x}px, ${cy + n.y}px, 0) translate(-50%, -50%)`;
      });
      requestAnimationFrame(tick);
    }

    const speeds = { inner: 0.0005, mid: 0.0003, outer: 0.0002 };
    function init() {
      const rect = viewport.getBoundingClientRect(); width = rect.width; height = rect.height;
      for(let i=0; i<200; i++) solve();
      let h = ''; for(let i=0; i<100; i++) h += `<div style="left:${Math.random()*100}%; top:${Math.random()*100}%; width:1.5px; height:1.5px; position:absolute; background:white; opacity:0.3; border-radius:50%"></div>`;
      starField.innerHTML = h;
      tick();
    }

    let isPanning = false; let sx, sy;
    viewport.addEventListener('mousedown', e => { if (e.target.closest('.planet-node')) return; isPanning = true; sx = e.clientX - panX; sy = e.clientY - panY; });
    window.addEventListener('mousemove', e => { if (!isPanning) return; panX = e.clientX - sx; panY = e.clientY - sy; world.style.transform = `translate(${panX}px, ${panY}px) scale(${scale})`; });
    window.addEventListener('mouseup', () => isPanning = false);
    viewport.addEventListener('wheel', e => { e.preventDefault(); const zoom = e.deltaY > 0 ? 0.95 : 1.05; scale = Math.min(Math.max(0.3, scale * zoom), 3); world.style.transform = `translate(${panX}px, ${panY}px) scale(${scale})`; }, { passive: false });

    nodeData.forEach(node => {
      node.el.addEventListener('mousedown', e => { e.stopPropagation(); node.isDragging = true; node.el.style.zIndex = "1000"; });
      window.addEventListener('mousemove', e => {
        if (!node.isDragging) return;
        const rect = viewport.getBoundingClientRect();
        node.x = (e.clientX - rect.left - panX) / scale - width/2;
        node.y = (e.clientY - rect.top - panY) / scale - height/2;
      });
      window.addEventListener('mouseup', () => { if(node.isDragging) { node.isDragging = false; node.el.style.zIndex = "30"; node.angle = Math.atan2(node.y, node.x); node.orbit = Math.hypot(node.x, node.y); } });
    });

    resetBtn.addEventListener('click', () => { panX = 0; panY = 0; scale = 1; world.style.transform = `translate(0,0) scale(1)`; });
    window.addEventListener('resize', () => { const r = viewport.getBoundingClientRect(); width = r.width; height = r.height; });
    init();
  })();
</script>
