---
import { Code } from "astro-expressive-code/components";
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import FeatureCard from "@/components/mdx/FeatureCard.astro";
import GitHubStats from "@/components/mdx/GitHubStats.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Home">
  <MainCard
    title="Welcome to Wuthering Heights"
    description="欢迎来到呼啸山庄."
    image="/image/home-banner.png"
    infoIcon="lucide:info"
  >
    <div class="space-y-12">
      <!-- Hero Section -->
      <section class="py-6">
        <div class="flex flex-col items-center text-center">
          <h1
            class="text-4xl md:text-5xl font-black mb-4 bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent leading-relaxed py-2"
          >
            🌟 Castlevania
          </h1>
          <p class="text-xl text-base-content/80 max-w-3xl mb-8 italic font-medium">
            "曾经沧海难为水 除却巫山不是云"
          </p>
          <div class="flex flex-wrap gap-4 justify-center">
            <a href="/blog" class="btn btn-primary btn-lg gap-2 shadow-lg hover:shadow-xl transition-all duration-300">
              <Icon name="lucide:book-open" class="w-5 h-5" />
              <span>Explore Blog</span>
            </a>
            <a href="https://github.com/heathc1iff-sec/" target="_blank" class="btn btn-outline btn-lg gap-2 hover:bg-base-200 transition-all duration-300">
              <Icon name="lucide:github" class="w-5 h-5" />
              <span>Star on GitHub</span>
            </a>
          </div>
        </div>
      </section>

      <!-- Features Section -->
      <section class="py-6">
        <h2 class="text-2xl font-bold mb-8 flex items-center gap-2 border-b border-base-content/10 pb-2">
          <Icon name="lucide:sparkles" class="w-6 h-6 text-primary" />
          <span>Preface</span>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <FeatureCard
            title="My Life"
            description="Share insights and experiences from my personal life journey."
            icon="lucide:sword"
            color="oklch(0.65 0.2 280)"
          />

          <FeatureCard
            title="CTF Write-Ups"
            description="Detailed write-ups of CTF challenges, including solutions and techniques."
            icon="lucide:flag"
            color="oklch(0.6 0.2 160)"
          />

          <FeatureCard
            title="Virtual Machines"
            description="Attack labs and vulnerable virtual machines for penetration testing practice."
            icon="lucide:book-text"
            color="oklch(0.6 0.2 200)"
          />

          <FeatureCard
            title="Learning Notes"
            description="Organized notes from my studies, experiments."
            icon="lucide:orbit"
            color="oklch(0.8 0.2 80)"
          />
        </div>
      </section>

      <!-- Disclaimer Section -->
      <section class="py-12 bg-base-200/40 mt-12 rounded-3xl border border-base-content/5 p-8 backdrop-blur-md shadow-inner">
        <div class="max-w-4xl mx-auto space-y-8">
          <h2 class="text-3xl font-black text-center flex items-center justify-center gap-3">
            <Icon name="lucide:shield-alert" class="w-8 h-8 text-primary" />
            <span>Blog Disclaimer</span>
          </h2>

          <p class="text-lg text-base-content/80 leading-relaxed text-center max-w-2xl mx-auto">
            The content of this blog is intended for <strong class="text-primary">educational and research purposes</strong> only, 
            focusing on <strong class="text-secondary">personal computer security</strong> knowledge.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-base-content/80">
            <div class="p-6 rounded-2xl bg-base-100/50 border border-base-content/10 shadow-sm hover:shadow-md transition-all duration-300">
              <h3 class="font-bold text-lg mb-2 flex items-center gap-2 text-error/80">
                <Icon name="lucide:ban" class="w-5 h-5" />
                No Misuse
              </h3>
              <p class="text-sm opacity-80 leading-relaxed">
                This blog does <strong>not encourage</strong> any form of illegal attacks, 
                security software bypassing, or unauthorized intrusion activities.
              </p>
            </div>

            <div class="p-6 rounded-2xl bg-base-100/50 border border-base-content/10 shadow-sm hover:shadow-md transition-all duration-300">
              <h3 class="font-bold text-lg mb-2 flex items-center gap-2 text-warning/80">
                <Icon name="lucide:scale" class="w-5 h-5" />
                Use at Your Own Risk
              </h3>
              <p class="text-sm opacity-80 leading-relaxed">
                Any losses, consequences, or legal liabilities arising from applying the content in real-world environments 
                are the sole responsibility of the reader.
              </p>
            </div>

            <div class="p-6 rounded-2xl bg-base-100/50 border border-base-content/10 shadow-sm hover:shadow-md transition-all duration-300">
              <h3 class="font-bold text-lg mb-2 flex items-center gap-2 text-success/80">
                <Icon name="lucide:gavel" class="w-5 h-5" />
                Legal Use Only
              </h3>
              <p class="text-sm opacity-80 leading-relaxed">
                The content must not be used for any illegal purposes and is strictly prohibited from being applied 
                to unauthorized systems.
              </p>
            </div>

            <div class="p-6 rounded-2xl bg-base-100/50 border border-base-content/10 shadow-sm hover:shadow-md transition-all duration-300">
              <h3 class="font-bold text-lg mb-2 flex items-center gap-2 text-info/80">
                <Icon name="lucide:refresh-cw" class="w-5 h-5" />
                Updates
              </h3>
              <p class="text-sm opacity-80 leading-relaxed">
                The author reserves the right to modify, supplement, or update this disclaimer when deemed necessary.
              </p>
            </div>
          </div>

          <div class="pt-6 border-t border-base-content/10">
            <p class="text-center text-sm text-base-content/40 italic">
              By accessing this blog, you acknowledge and agree to the above terms.
            </p>
          </div>
        </div>
      </section>
    </div>
  </MainCard>
</BaseLayout>
