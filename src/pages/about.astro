---
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import GitHubStats from "@/components/mdx/GitHubStats.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const focusAreas = [
  {
    icon: "lucide:shield",
    title: "Web Security",
    description: "Hands-on web security practice, exploit development, and defense analysis in controlled labs.",
  },
  {
    icon: "lucide:crosshair",
    title: "Red Team Training",
    description: "Continuous red team mindset training with offensive workflows and post-exploitation methodology.",
  },
  {
    icon: "lucide:book-open",
    title: "Knowledge Sharing",
    description: "Write-ups and notes that turn complex technical problems into practical, repeatable learning.",
  },
];
---

<BaseLayout title="About">
  <MainCard
    title="About Heathc1iff"
    description="About Heathc1iff"
    image="/image/about-banner.png"
    infoIcon="lucide:user"
  >
    <div class="about-stack">
      <section class="about-hero">
        <div class="avatar">
          <div class="about-avatar-frame">
            <img src="/friends/me.jpg" alt="Heathc1iff" width="160" height="160" loading="eager" />
          </div>
        </div>

        <div class="flex-1 text-center md:text-left">
          <h1 class="about-name">Heathc1iff</h1>
          <p class="text-xl text-base-content/80 mb-4">Web Security and Red Team</p>

          <div class="about-link-row">
            <a
              href="https://github.com/heathc1iff-sec"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-sm btn-outline gap-2"
            >
              <Icon name="lucide:github" class="w-4 h-4" />
              <span>GitHub</span>
            </a>
            <a
              href="https://twitter.com"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-sm btn-outline gap-2"
            >
              <Icon name="lucide:twitter" class="w-4 h-4" />
              <span>Twitter</span>
            </a>
            <a href="mailto:heathc1iff_sec@qq.com" class="btn btn-sm btn-outline gap-2">
              <Icon name="lucide:mail" class="w-4 h-4" />
              <span>Email</span>
            </a>
          </div>

          <p class="about-intro">
            Hi, I am Heathc1iff. I am a third-year university student focused on web security and a member of the
            XMCVE security team. I am currently preparing for OSEP while building long-term offensive security depth.
          </p>
        </div>
      </section>

      <section class="about-section">
        <h2 class="about-section-title">
          <Icon name="lucide:github" class="w-6 h-6 text-primary" />
          <span>GitHub Statistics</span>
        </h2>

        <div class="about-section-panel">
          <GitHubStats username="heathc1iff-sec" showLanguages={false} showCommitGraph={true} />
        </div>
      </section>

      <section class="about-section">
        <h2 class="about-section-title">
          <Icon name="lucide:sparkles" class="w-6 h-6 text-primary" />
          <span>Focus Areas</span>
        </h2>

        <div class="about-focus-grid">
          {
            focusAreas.map((item) => (
              <article class="about-focus-card">
                <div class="about-focus-icon">
                  <Icon name={item.icon} class="w-5 h-5" />
                </div>
                <h3 class="text-lg font-semibold mb-2">{item.title}</h3>
                <p class="text-sm text-base-content/75 leading-relaxed">{item.description}</p>
              </article>
            ))
          }
        </div>
      </section>
    </div>
  </MainCard>
</BaseLayout>
